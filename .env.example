# Copy to .env.local for local dev (it is gitignored).

# Local development uses a SQLite file (no auth token needed):
DATABASE_URL="file:./prisma/dev.db"

# Production (Vercel) uses Turso — set these in the Vercel dashboard, NOT here:
#   DATABASE_URL="libsql://seo-dept-<your-org>.turso.io"
#   DATABASE_AUTH_TOKEN="<turso db token>"
