# Copy to .env.local for local dev (gitignored).
#
# Local dev needs a Postgres database. Easiest with Docker:
#   docker run --name seo-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=seo_dept \
#     -p 5432:5432 -d postgres:16
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seo_dept"

# Production (Cloud Run) reads DATABASE_URL from Secret Manager (Cloud SQL socket
# form: ...@localhost/seo_dept?host=/cloudsql/<connection-name>). Do not set it here.
